# ============================================================
# MakeIoT — .gitignore
# ============================================================

# ---- Environment files (never commit real secrets) ----
.env
.env.*
!.env.example
*.env
!.env.example
*.pem
*.key
credentials.json
*token.json*
*credentials.json*

# ---- Node / React ----
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Frontend builds ----
frontend/build/
frontend/dist/
build/
dist/

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/
.env.venv
.python-version
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
.eggs/

# ---- Editors / OS ----
.idea/
.vscode/
.DS_Store
Thumbs.db

# ---- Test artefacts (internal only) ----
test_reports/
test_result.md
memory/

# ---- Platform / build caches ----
.emergent/
.vercel/
.next/
.cache/

# ---- Internal design docs (not for GitHub) ----
design_guidelines.json

# ---- Misc ----
dump.rdb
*.zip
*.tar.gz
*.tar
*.tgz
.credentials
